# ============================================
# FITNESS HUB - ENVIRONMENT CONFIGURATION
# ============================================
# Rename this file to .env and fill in your details
# DO NOT commit .env file to git - add to .gitignore

# ============================================
# SUPABASE CONFIGURATION (DATABASE)
# ============================================

# Supabase Project URL (includes .supabase.co domain)
NEXT_PUBLIC_SUPABASE_URL=https://aaejtdniyakebgztsbxz.supabase.co

# Supabase Publishable Key (ANON key - safe for frontend)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_2AVJ9XPMm2fjgCbU4G4Rww_40qklJnQ

# Note: These credentials are also configured in:
# - assets/js/supabase-config.js

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Choose email service: gmail | sendgrid | smtp
EMAIL_SERVICE=gmail

# ---- GMAIL SETUP (Option 1) ----
# 1. Enable 2-Factor Authentication on Gmail
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Copy 16-character password here (NOT your Gmail password!)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---- SENDGRID SETUP (Option 2) ----
# Get API Key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-api-key-here

# ---- CUSTOM SMTP (Option 3) ----
# For other email services (Outlook, Zoho, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port (default: 5000)
PORT=5000

# Environment: development | production
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# OTP CONFIGURATION
# ============================================

# OTP expiry in minutes (default: 5)
OTP_EXPIRY_MINUTES=5

# Max resend attempts per email per hour (default: 5)
MAX_OTP_REQUESTS=5

# ============================================
# DATABASE (Optional - for production)
# ============================================

# MongoDB connection string (if using persistent storage)
MONGODB_URI=mongodb://localhost:27017/fitness-hub

# Redis connection (for distributed OTP storage)
REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY
# ============================================

# JWT Secret for token generation
JWT_SECRET=your-secret-key-here-min-32-chars

# API Key for backend requests (optional)
API_KEY=your-api-key-here

# ============================================
# LOGGING
# ============================================

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
ENABLE_OTP_EMAIL=true
ENABLE_GOOGLE_LOGIN=true
ENABLE_RATE_LIMITING=true
SHOW_OTP_IN_CONSOLE=true
